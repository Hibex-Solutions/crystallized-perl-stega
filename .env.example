# Stega — variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores para o seu ambiente local.
# NUNCA comite o arquivo .env com credenciais reais.

# ─── Aplicação ────────────────────────────────────────────────────────────────

# Segredo para assinatura de cookies de sessão (mude em produção)
STEGA_SECRET=dev_secret_mude_em_producao

# Porta da aplicação (padrão: 3000)
# STEGA_PORT=3000

# ─── Banco de dados ───────────────────────────────────────────────────────────
# Três instâncias PostgreSQL independentes (ADR-023) — nunca a mesma URL/
# credencial reaproveitada entre elas, mesmo que apontem para o mesmo servidor
# em desenvolvimento local. Servidor/porta/banco nunca carregam credencial
# (Revisão 2026-07-04 da ADR-016) — username/password são variáveis à parte.

# db-app — dados relacionais e JSONB (ADR-016/ADR-017)
POSTGRESQL_APP_URL=postgresql://localhost:55432/stega-app
POSTGRESQL_APP_USERNAME=postgres
POSTGRESQL_APP_PASSWORD=postgres_dev
# Usuário de migration (DDL: CREATE, ALTER, DROP) — usado por eng/migrate.pl.
# Em produção, use um usuário dedicado sem privilégios DDL para APP_USERNAME.
# Em desenvolvimento com Docker Compose, o usuário postgres é suficiente para os dois.
POSTGRESQL_APP_MIGRATION_USERNAME=postgres
POSTGRESQL_APP_MIGRATION_PASSWORD=postgres_dev

# db-jobs — backend do Minion (ADR-023)
POSTGRESQL_JOBS_URL=postgresql://localhost:55433/stega-jobs
POSTGRESQL_JOBS_USERNAME=postgres
POSTGRESQL_JOBS_PASSWORD=postgres_dev

# db-events — PgQue, fila de eventos multi-consumidor (ADR-022/ADR-023)
POSTGRESQL_EVENTS_URL=postgresql://localhost:55434/stega-events
POSTGRESQL_EVENTS_USERNAME=postgres
POSTGRESQL_EVENTS_PASSWORD=postgres_dev
RABBITMQ_VHOST=/

# ─── Keycloak / Autenticação ──────────────────────────────────────────────────

# URL usada pelo servidor para chamadas servidor→servidor ao Keycloak
# (troca de código por token, busca de chave pública via JWKS).
# Em Docker Compose, aponta para o hostname interno: http://keycloak:8080
KEYCLOAK_URL=http://localhost:8080

# URL do Keycloak visível pelo browser (redirects de login e troca de senha).
# Necessária quando a URL interna (KEYCLOAK_URL) não é acessível pelo browser,
# como ao rodar a aplicação em container Docker e o Keycloak em outro container.
# Se omitida, usa KEYCLOAK_URL (adequado para desenvolvimento local sem Docker).
# KEYCLOAK_FRONTEND_URL=http://localhost:8080

KEYCLOAK_REALM=stega
KEYCLOAK_CLIENT_ID=stega-web

# Segredo do client OIDC (deixe vazio para clients públicos — tipo "public" no Keycloak)
KEYCLOAK_CLIENT_SECRET=

# Credenciais do usuário administrador bootstrap do Keycloak (mesmas de
# KC_BOOTSTRAP_ADMIN_USERNAME/PASSWORD no compose.yml) — só para preparar o
# ambiente de teste (eng/keycloak_test_users.pl via API administrativa).
# NÃO faz parte de Stega::Config: nenhum consumidor da aplicação em runtime
# usa a API administrativa do Keycloak, só este script de setup de teste.
# KEYCLOAK_ADMIN_USER=admin
# KEYCLOAK_ADMIN_PASSWORD=admin

# ─── Webhooks externos ────────────────────────────────────────────────────────

# Os segredos de autenticação dos webhooks (/api/v1/webhooks/github e
# /api/v1/webhooks/generic) não ficam em variável de ambiente — são
# credenciais administráveis em banco, cadastradas por um admin em
# /admin/webhook-credentials (ver Stega::Domain::WebhookCredential).

# ─── Modo de teste ────────────────────────────────────────────────────────────

# Quando definida, a aplicação aceita tokens JWT assinados com HS256 usando
# este segredo — permite testes de API sem Keycloak em execução.
# Em produção, a chave pública RS256 é obtida automaticamente via JWKS do Keycloak:
#   {KEYCLOAK_URL}/realms/{KEYCLOAK_REALM}/protocol/openid-connect/certs
# NUNCA defina esta variável em produção.
TEST_JWT_SECRET=test_secret_apenas_para_desenvolvimento
