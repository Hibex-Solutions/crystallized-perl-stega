<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title() // 'Stega' %> — Stega</title>
  <link rel="icon" type="image/svg+xml" href="/logo.svg">
  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
  <style>
    :root {
      --stega-blue:   #007399;
      --stega-orange: #F97316;
      --stega-purple: #8B5CF6;
      --stega-cyan:   #06B6D4;
      --stega-dark:   #0F172A;
    }
    body { background-color: #f8f9fa; }
    .navbar-brand { color: var(--stega-cyan) !important; font-weight: 700; }
    .badge-open        { background-color: var(--stega-blue); }
    .badge-in_progress { background-color: var(--stega-orange); }
    .badge-waiting     { background-color: #6c757d; }
    .badge-resolved    { background-color: #198754; }
    .badge-closed      { background-color: #343a40; }
    .priority-critical { border-left: 4px solid #dc3545; }
    .priority-high     { border-left: 4px solid var(--stega-orange); }
    .priority-medium   { border-left: 4px solid var(--stega-cyan); }
    .priority-low      { border-left: 4px solid #6c757d; }
    .comment-internal  { background-color: #fff3cd; border-left: 4px solid #ffc107; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: var(--stega-dark);">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <img src="/logo.svg" alt="" height="28">
        Stega
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="nav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link" href="/tickets">Tickets</a>
          </li>
          % my $user = stash('current_user') // {};
          % if (($user->{role} // '') eq 'admin') {
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Admin</a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/admin/products">Produtos</a></li>
              <li><a class="dropdown-item" href="/admin/users">Usuários</a></li>
            </ul>
          </li>
          % }
        </ul>
        <ul class="navbar-nav">
          % if ($user->{id}) {
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <%= $user->{display_name} // 'Usuário' %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/profile">Perfil</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/logout">Sair</a></li>
            </ul>
          </li>
          % } else {
          <li class="nav-item">
            <a class="nav-link" href="/login">Entrar</a>
          </li>
          % }
        </ul>
      </div>
    </div>
  </nav>

  <main class="container mt-4 pb-5">
    %= content
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
